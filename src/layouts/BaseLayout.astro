---
import { resolveLocale, alternatesFor, t } from '../i18n/t';
import { LOCALE_META, isRTL, hreflangFor, ogLocaleFor } from '../i18n/config';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  robots?: string;
  jsonLd?: object;
  locale?: string;
}

const SITE_NAME = 'ScanFence';
const SITE_URL = 'https://scanfence.com';
const DEFAULT_OG_IMAGE = `${SITE_URL}/assets/scanfence-logo-black.png`;

const locale = resolveLocale(Astro.props.locale ?? Astro.currentLocale);
const DEFAULT_DESCRIPTION = t('site.description', locale);

const {
  title,
  description = DEFAULT_DESCRIPTION,
  canonical,
  ogImage = DEFAULT_OG_IMAGE,
  ogType = 'website',
  robots = 'index,follow',
  jsonLd,
} = Astro.props;

const resolvedCanonical = canonical ?? `${SITE_URL}${Astro.url.pathname}`;
const resolvedOgImage = ogImage.startsWith('http') ? ogImage : `${SITE_URL}${ogImage}`;
const alternates = alternatesFor(Astro.url.pathname, SITE_URL);
const htmlLang = hreflangFor(locale);
const htmlDir = isRTL(locale) ? 'rtl' : 'ltr';
const ogLocale = ogLocaleFor(locale);

import '@fontsource-variable/inter/wght.css';
import '@fontsource-variable/space-grotesk/wght.css';
import '@fontsource-variable/geist/wght.css';
import '@fontsource-variable/jetbrains-mono/wght.css';
import '@fontsource/newsreader/400-italic.css';
import spaceGroteskUrl from '@fontsource-variable/space-grotesk/files/space-grotesk-latin-wght-normal.woff2?url';
import interUrl from '@fontsource-variable/inter/files/inter-latin-wght-normal.woff2?url';
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang={htmlLang} dir={htmlDir}>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <!-- Opt out of host-side mod_pagespeed / ngx_pagespeed rewriting (Astro already optimizes; the host's beacon URL 404s). -->
  <meta http-equiv="x-mod-pagespeed" content="off">
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content={robots} />
  <meta name="author" content={SITE_NAME} />
  <meta name="theme-color" content="#F1ECE0" />
  <link rel="canonical" href={resolvedCanonical} />

  {alternates.map(alt => (
    <link rel="alternate" hreflang={alt.hreflang} href={alt.href} />
  ))}

  <!-- Open Graph -->
  <meta property="og:site_name" content={SITE_NAME} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content={ogType} />
  <meta property="og:url" content={resolvedCanonical} />
  <meta property="og:image" content={resolvedOgImage} />
  <meta property="og:locale" content={ogLocale} />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={resolvedOgImage} />

  <link rel="icon" type="image/png" href="/assets/favicon.png">
  <link rel="preload" as="font" type="font/woff2" href={spaceGroteskUrl} crossorigin />
  <link rel="preload" as="font" type="font/woff2" href={interUrl} crossorigin />
  {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
</head>
<body>
  <slot />
</body>
</html>
