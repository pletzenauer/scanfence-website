---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  pageTitle: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  jsonLd?: object;
}

const { title, pageTitle, description, canonical, ogImage, jsonLd } = Astro.props;
---

<BaseLayout title={title} description={description} canonical={canonical} ogImage={ogImage} jsonLd={jsonLd}>
  <Header />
  <main>
    <div class="wp-content">
      <slot />
    </div>
  </main>
  <Footer />
</BaseLayout>
