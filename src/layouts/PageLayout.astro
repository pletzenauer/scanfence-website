---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import type { Locale } from '../i18n/config';

interface Props {
  title: string;
  pageTitle: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  jsonLd?: object | object[];
  locale?: string;
  availableLocales?: ReadonlyArray<Locale>;
}

const { title, pageTitle, description, canonical, ogImage, jsonLd, locale, availableLocales } = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  ogImage={ogImage}
  jsonLd={jsonLd}
  locale={locale}
  availableLocales={availableLocales}
>
  <Header />
  <main>
    <div class="wp-content">
      <slot />
    </div>
  </main>
  <Footer />
</BaseLayout>
