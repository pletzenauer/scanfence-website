---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import BlogCard from '../../components/BlogCard.astro';
import Pagination from '../../components/Pagination.astro';
import { getPosts, getCategories, getMedia, stripHtml, formatDate } from '../../lib/wordpress';
import { DEFAULT_LOCALE } from '../../i18n/config';
import { t } from '../../i18n/t';

const locale = DEFAULT_LOCALE;
const { posts, totalPages } = await getPosts(1, 12);
const categories = await getCategories();

const postsWithData = await Promise.all(
  posts.map(async (post) => {
    const media = post.featured_media ? await getMedia(post.featured_media) : null;
    const category = categories.find(c => post.categories.includes(c.id));
    return {
      title: post.title.rendered,
      slug: post.slug,
      excerpt: stripHtml(post.excerpt.rendered).slice(0, 160),
      date: formatDate(post.date),
      imageUrl: media?.source_url,
      category: category?.name,
    };
  })
);

const blogJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  '@id': 'https://scanfence.com/blog/',
  name: 'ScanFence Blog',
  description: 'Articles about QR codes, geofencing, and location-based marketing.',
  url: 'https://scanfence.com/blog/',
  publisher: { '@type': 'Organization', name: 'ScanFence', url: 'https://scanfence.com/' },
  blogPost: postsWithData.map(p => ({
    '@type': 'BlogPosting',
    headline: p.title,
    url: `https://scanfence.com/blog/${p.slug}/`,
    datePublished: p.date,
  })),
};
---

<BaseLayout
  title={t('blog.title', locale)}
  description={t('blog.description', locale)}
  canonical="https://scanfence.com/blog/"
  jsonLd={blogJsonLd}
  locale={locale}
>
  <Header />
  <main>
    <div class="page-header">
      <div class="container">
        <h1>{t('blog.heading', locale)}</h1>
      </div>
    </div>
    <section class="section">
      <div class="container">
        <div class="blog-grid">
          {postsWithData.map(post => (
            <BlogCard {...post} />
          ))}
        </div>
        <Pagination currentPage={1} totalPages={totalPages} basePath="/blog/page" firstPagePath="/blog/" />
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
