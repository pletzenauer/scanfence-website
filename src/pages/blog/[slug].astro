---
import { getAllPosts, getPost, getMedia, getCategories, getPostsByCategory, stripHtml, formatDate, rewriteWPLinks, rewriteSchemaUrls, demoteAllH1s, lazyLoadBodyImages, descriptionExcerpt } from '../../lib/wordpress';
import PostLayout from '../../layouts/PostLayout.astro';
import RelatedPosts from '../../components/RelatedPosts.astro';
import { DEFAULT_LOCALE } from '../../i18n/config';
import { postAvailableLocales } from '../../i18n/wp-cache';
import { breadcrumbList } from '../../lib/schema';
import { t } from '../../i18n/t';

export async function getStaticPaths() {
  const posts = await getAllPosts();
  const slugs = posts.map(p => p.slug);
  return posts.map(post => ({ params: { slug: post.slug }, props: { allSlugs: slugs } }));
}

const locale = DEFAULT_LOCALE;
const { slug } = Astro.params;
const { allSlugs } = Astro.props as { allSlugs: string[] };
const post = await getPost(slug!);
if (!post) return Astro.redirect('/blog/');

const media = post.featured_media ? await getMedia(post.featured_media) : null;
const categories = await getCategories();
const postCategory = categories.find(c => post.categories.includes(c.id));

const seo = post.yoast_head_json;
const knownPostSlugs = new Set<string>(allSlugs);
const rewrittenContent = lazyLoadBodyImages(demoteAllH1s(rewriteWPLinks(post.content.rendered, knownPostSlugs)));

// Yoast emits canonicals against WP's permalink structure (no /blog/ prefix).
// Override with the actual Astro URL so search engines index the right page.
const canonical = `https://scanfence.com/blog/${post.slug}/`;
const fixedSchema = seo?.schema
  ? rewriteSchemaUrls(seo.schema, knownPostSlugs)
  : undefined;
const description = seo?.description || descriptionExcerpt(post.excerpt.rendered || post.content.rendered);
const availableLocales = postAvailableLocales(post.slug);

const breadcrumbs = [
  { name: t('nav.home', locale), href: 'https://scanfence.com/' },
  { name: t('nav.blog', locale), href: 'https://scanfence.com/blog/' },
  ...(postCategory ? [{ name: postCategory.name, href: `https://scanfence.com/category/${postCategory.slug}/` }] : []),
  { name: post.title.rendered },
];
const breadcrumbSchema = breadcrumbList(breadcrumbs.map(b => ({ name: b.name, url: b.href })));
const jsonLdBlocks = [fixedSchema, breadcrumbSchema].filter(Boolean) as object[];

// Related posts — 3 most recent from the same category, excluding this post.
let related: Array<{ title: string; slug: string; excerpt: string; date: string; imageUrl?: string; category?: string }> = [];
if (postCategory) {
  const { posts: catPosts } = await getPostsByCategory(postCategory.id, 1, 6);
  const others = catPosts.filter(p => p.slug !== post.slug).slice(0, 3);
  related = await Promise.all(others.map(async p => {
    const m = p.featured_media ? await getMedia(p.featured_media) : null;
    return {
      title: p.title.rendered,
      slug: p.slug,
      excerpt: stripHtml(p.excerpt.rendered).slice(0, 160),
      date: formatDate(p.date),
      imageUrl: m?.source_url,
      category: postCategory.name,
    };
  }));
}
---

<PostLayout
  title={seo?.title || post.title.rendered}
  description={description}
  canonical={canonical}
  ogImage={seo?.og_image?.[0]?.url || media?.source_url}
  date={formatDate(post.date)}
  dateISO={post.date}
  category={postCategory?.name}
  featuredImage={media?.source_url}
  featuredImageAlt={media?.alt_text}
  featuredImageWidth={media?.media_details?.width}
  featuredImageHeight={media?.media_details?.height}
  breadcrumbs={breadcrumbs}
  jsonLd={jsonLdBlocks}
  locale={locale}
  availableLocales={availableLocales}
>
  <Fragment set:html={rewrittenContent} />
  <Fragment slot="after-content">
    <RelatedPosts
      posts={related}
      heading={t('blog.related.heading', locale)}
      eyebrow={t('blog.related.eyebrow', locale)}
    />
  </Fragment>
</PostLayout>
