---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CTA from '../components/CTA.astro';
import { resolveLocale, localizedUrl, t } from '../i18n/t';

const locale = resolveLocale(Astro.currentLocale);
const title = t('pricing.title', locale);
const description = t('pricing.description', locale);
const canonical = `https://scanfence.com${localizedUrl('/pricing/', locale)}`;

const tierKeys = ['starter', 'growth', 'scale'] as const;
const tiers = tierKeys.map(k => ({
  key: k,
  name: t(`pricing.tier.${k}.name`, locale),
  eyebrow: t(`pricing.tier.${k}.eyebrow`, locale),
  price: k === 'starter' ? '29' : k === 'growth' ? '79' : '199',
  cadence: t('pricing.cadence', locale),
  blurb: t(`pricing.tier.${k}.blurb`, locale),
  cta: {
    label: t(`pricing.tier.${k}.cta`, locale),
    href: `https://app.scanfence.com/signup?plan=${k}`,
  },
  features: [1, 2, 3, 4, 5, 6].map(i => t(`pricing.tier.${k}.feature${i}`, locale)),
  featured: k === 'growth',
}));

const compare = [
  { row: t('pricing.compare.row.codes',        locale), s: '5',        g: '50',                                          x: '500' },
  { row: t('pricing.compare.row.scans',        locale), s: '10,000',   g: '100,000',                                     x: '1,000,000' },
  { row: t('pricing.compare.row.geofences',    locale), s: '2',        g: t('pricing.compare.val.unlimited', locale),    x: t('pricing.compare.val.unlimited', locale) },
  { row: t('pricing.compare.row.timeRouting',  locale), s: '✓',        g: '✓',                                           x: '✓' },
  { row: t('pricing.compare.row.api',          locale), s: '—',        g: '✓',                                           x: '✓' },
  { row: t('pricing.compare.row.seats',        locale), s: '1',        g: '3',                                           x: t('pricing.compare.val.unlimited', locale) },
  { row: t('pricing.compare.row.domains',      locale), s: '—',        g: '—',                                           x: '✓' },
  { row: t('pricing.compare.row.sla',          locale), s: '—',        g: '—',                                           x: '99.9%' },
  { row: t('pricing.compare.row.support',      locale), s: t('pricing.compare.val.email', locale), g: t('pricing.compare.val.priority', locale), x: t('pricing.compare.val.prioritySla', locale) },
];

const faqKeys = [1, 2, 3, 4, 5, 6, 7];
const faqs = faqKeys.map(i => ({
  q: t(`pricing.faq.q${i}`, locale),
  a: t(`pricing.faq.a${i}`, locale),
}));

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  '@id': canonical,
  name: 'ScanFence',
  description,
  brand: { '@type': 'Brand', name: 'ScanFence' },
  offers: {
    '@type': 'AggregateOffer',
    priceCurrency: 'EUR',
    lowPrice: '29',
    highPrice: '199',
    offerCount: tiers.length,
    availability: 'https://schema.org/InStock',
    url: canonical,
  },
};

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<BaseLayout title={title} description={description} canonical={canonical} jsonLd={jsonLd}>
  <Header />
  <main>
    <section class="pricing-hero">
      <div class="container">
        <span class="eyebrow">{t('pricing.hero.eyebrow', locale)}</span>
        <h1>
          {t('pricing.hero.heading.line1', locale)} <span class="serif-accent">{t('pricing.hero.heading.line2', locale)}</span>
        </h1>
        <p class="pricing-lede">{t('pricing.hero.lede', locale)}</p>
        <div class="metadata-strip">
          <span>{t('common.metadata.eurNet', locale)}</span>
          <span>{t('common.metadata.trial', locale)}</span>
          <span>{t('common.metadata.euIreland', locale)}</span>
          <span>{t('common.metadata.soc2', locale)}</span>
        </div>
      </div>
    </section>

    <section class="pricing-tiers section">
      <div class="container">
        <ul class="pricing-grid">
          {tiers.map(tier => (
            <li class={`pricing-card${tier.featured ? ' pricing-card--featured' : ''}`}>
              <header class="pricing-card-head">
                <span class="eyebrow eyebrow--mute">{tier.eyebrow}</span>
                <h2>{tier.name}</h2>
                <p class="pricing-card-blurb">{tier.blurb}</p>
              </header>
              <div class="pricing-card-price">
                <span class="pricing-card-currency">€</span>
                <span class="pricing-card-amount">{tier.price}</span>
                <span class="pricing-card-cadence">{tier.cadence}</span>
              </div>
              <a href={tier.cta.href} class={`btn ${tier.featured ? 'btn-primary' : 'btn-ghost'} btn-lg pricing-card-cta`}>
                {tier.cta.label}
              </a>
              <ul class="pricing-card-features">
                {tier.features.map(f => (
                  <li><span class="pricing-card-tick" aria-hidden="true">✓</span>{f}</li>
                ))}
              </ul>
            </li>
          ))}
        </ul>

        <div class="pricing-enterprise">
          <div class="pricing-enterprise-copy">
            <span class="eyebrow eyebrow--mute">{t('pricing.enterprise.eyebrow', locale)}</span>
            <h3>{t('pricing.enterprise.heading', locale)}</h3>
            <p>{t('pricing.enterprise.body', locale)}</p>
          </div>
          <a href={`${localizedUrl('/contact/', locale)}?topic=sales`} class="btn btn-ghost btn-lg">{t('pricing.enterprise.cta', locale)}</a>
        </div>
      </div>
    </section>

    <section class="pricing-compare section">
      <div class="container">
        <span class="eyebrow">{t('pricing.compare.eyebrow', locale)}</span>
        <h2>{t('pricing.compare.heading', locale)}</h2>
        <div class="pricing-compare-wrap">
          <table class="pricing-compare-table">
            <thead>
              <tr>
                <th scope="col"></th>
                <th scope="col">{t('pricing.compare.col.starter', locale)}</th>
                <th scope="col">{t('pricing.compare.col.growth', locale)}</th>
                <th scope="col">{t('pricing.compare.col.scale', locale)}</th>
              </tr>
            </thead>
            <tbody>
              {compare.map(row => (
                <tr>
                  <th scope="row">{row.row}</th>
                  <td>{row.s}</td>
                  <td>{row.g}</td>
                  <td>{row.x}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <section class="pricing-faq section">
      <div class="container pricing-faq-container">
        <span class="eyebrow">{t('pricing.faq.eyebrow', locale)}</span>
        <h2>{t('pricing.faq.heading', locale)}</h2>
        <div class="pricing-faq-list">
          {faqs.map((f, i) => (
            <details open={i === 0}>
              <summary>{f.q}</summary>
              <div class="pricing-faq-answer">{f.a}</div>
            </details>
          ))}
        </div>
      </div>
    </section>

    <CTA />
  </main>
  <Footer />
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
</BaseLayout>

<style>
  .pricing-hero {
    padding: var(--space-8) 0 var(--space-7);
    background: var(--d01-paper);
    border-bottom: var(--rule-hard);
  }
  .pricing-hero h1 {
    font-size: clamp(48px, 6vw, 80px);
    font-weight: 500;
    line-height: 1.02;
    letter-spacing: -0.02em;
    margin: var(--space-3) 0 var(--space-5);
  }
  .pricing-lede {
    font-size: 18px;
    color: var(--d01-steel);
    line-height: 1.55;
    margin-bottom: var(--space-6);
    max-width: 56ch;
  }

  .pricing-tiers { background: var(--d01-paper-hi); }
  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-5);
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .pricing-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding: var(--space-6);
    background: var(--d01-paper);
    border: var(--rule-hard);
  }
  .pricing-card--featured {
    background: var(--d01-ink);
    color: var(--d01-paper-hi);
    border-color: var(--d01-ink);
  }
  .pricing-card--featured .pricing-card-blurb,
  .pricing-card--featured .pricing-card-features li {
    color: rgba(247, 243, 232, 0.78);
  }
  .pricing-card--featured .eyebrow--mute { color: rgba(247, 243, 232, 0.55); }
  .pricing-card-head h2 {
    font-size: 28px;
    font-weight: 500;
    letter-spacing: -0.01em;
    margin: var(--space-2) 0 var(--space-2);
  }
  .pricing-card-blurb {
    font-size: 15px;
    line-height: 1.5;
    color: var(--d01-steel);
    max-width: 32ch;
  }
  .pricing-card-price {
    display: flex;
    align-items: baseline;
    gap: 4px;
    padding: var(--space-3) 0;
    border-top: var(--rule);
    border-bottom: var(--rule);
  }
  .pricing-card--featured .pricing-card-price {
    border-color: rgba(247, 243, 232, 0.2);
  }
  .pricing-card-currency {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 500;
  }
  .pricing-card-amount {
    font-family: var(--font-display);
    font-size: 56px;
    font-weight: 500;
    letter-spacing: -0.02em;
    line-height: 1;
  }
  .pricing-card-cadence {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--d01-mute);
    margin-inline-start: 6px;
  }
  .pricing-card--featured .pricing-card-cadence { color: rgba(247, 243, 232, 0.55); }
  .pricing-card-cta { align-self: stretch; text-align: center; }
  .pricing-card-features {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    font-family: var(--font-ui);
    font-size: 15px;
    color: var(--d01-ink);
  }
  .pricing-card-features li {
    display: flex;
    align-items: baseline;
    gap: var(--space-2);
    line-height: 1.5;
  }
  .pricing-card-tick {
    font-family: var(--font-mono);
    color: var(--d01-signal);
    font-size: 12px;
  }
  .pricing-card--featured .pricing-card-tick { color: var(--d01-paper-hi); }

  .pricing-enterprise {
    margin-top: var(--space-7);
    padding: var(--space-6);
    border: var(--rule-hard);
    background: var(--d01-paper);
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: var(--space-5);
  }
  .pricing-enterprise-copy h3 {
    font-size: 24px;
    font-weight: 500;
    letter-spacing: -0.01em;
    margin: var(--space-2) 0 var(--space-2);
  }
  .pricing-enterprise-copy p {
    color: var(--d01-steel);
    font-size: 15px;
    line-height: 1.55;
    max-width: 68ch;
  }

  .pricing-compare h2 {
    font-size: clamp(32px, 3.5vw, 48px);
    font-weight: 500;
    letter-spacing: -0.015em;
    margin: var(--space-3) 0 var(--space-6);
  }
  .pricing-compare-wrap { overflow-x: auto; border: var(--rule-hard); }
  .pricing-compare-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 14px;
  }
  .pricing-compare-table th,
  .pricing-compare-table td {
    padding: var(--space-3) var(--space-4);
    text-align: start;
    border-bottom: var(--rule);
    font-family: var(--font-ui);
  }
  .pricing-compare-table thead th {
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--d01-mute);
    background: var(--d01-paper-hi);
    border-bottom: var(--rule-hard);
  }
  .pricing-compare-table tbody th {
    color: var(--d01-ink);
    font-weight: 500;
  }
  .pricing-compare-table tbody td { color: var(--d01-steel); }

  /* FAQ */
  .pricing-faq-container { max-width: 800px; }
  .pricing-faq h2 {
    font-size: clamp(32px, 3.5vw, 48px);
    font-weight: 500;
    letter-spacing: -0.015em;
    margin: var(--space-3) 0 var(--space-6);
  }
  .pricing-faq-list { border-top: var(--rule-hard); }
  .pricing-faq details { border-bottom: var(--rule-hard); }
  .pricing-faq summary {
    padding: var(--space-5) 0;
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 20px;
    color: var(--d01-ink);
    cursor: pointer;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-4);
  }
  .pricing-faq summary::-webkit-details-marker { display: none; }
  .pricing-faq summary::after {
    content: '+';
    font-family: var(--font-mono);
    font-size: 20px;
    color: var(--d01-mute);
    line-height: 1;
  }
  .pricing-faq details[open] summary::after { content: '−'; }
  .pricing-faq-answer {
    padding: 0 0 var(--space-5);
    color: var(--d01-steel);
    font-size: 16px;
    line-height: 1.65;
    max-width: 64ch;
  }

  @media (max-width: 900px) {
    .pricing-grid { grid-template-columns: 1fr; }
    .pricing-enterprise { grid-template-columns: 1fr; }
  }
</style>
