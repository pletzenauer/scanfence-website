---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CTA from '../components/CTA.astro';
import { resolveLocale, localizedUrl, t } from '../i18n/t';

const locale = resolveLocale(Astro.currentLocale);
const title = t('pricing.title', locale);
const description = t('pricing.description', locale);
const canonical = `https://scanfence.com${localizedUrl('/pricing/', locale)}`;

const tierKeys = ['basic', 'starter', 'professional'] as const;
const tierPricing = {
  basic:        { monthly: '4.99',  annual: '49'  },
  starter:      { monthly: '14.99', annual: '149' },
  professional: { monthly: '44.99', annual: '449' },
} as const;
const tiers = tierKeys.map(k => ({
  key: k,
  name: t(`pricing.tier.${k}.name`, locale),
  eyebrow: t(`pricing.tier.${k}.eyebrow`, locale),
  priceMonthly: tierPricing[k].monthly,
  priceAnnual: tierPricing[k].annual,
  blurb: t(`pricing.tier.${k}.blurb`, locale),
  cta: {
    label: t(`pricing.tier.${k}.cta`, locale),
    href: `https://app.scanfence.com/signup?plan=${k}`,
  },
  features: [1, 2, 3, 4, 5, 6].map(i => t(`pricing.tier.${k}.feature${i}`, locale)),
  featured: k === 'starter',
}));

const compare = [
  { row: t('pricing.compare.row.codes',     locale), s: '100',    g: '500',     x: '2,500' },
  { row: t('pricing.compare.row.scans',     locale), s: '25,000', g: '125,000', x: '1,250,000' },
  { row: t('pricing.compare.row.geofences', locale), s: '100',    g: '500',     x: '2,500' },
  { row: t('pricing.compare.row.seats',     locale), s: '2',      g: '3',       x: '10' },
  { row: t('pricing.compare.row.trial',     locale), s: '30d',    g: '30d',     x: '30d' },
  { row: t('pricing.compare.row.region',    locale), s: 'EU · Ireland', g: 'EU · Ireland', x: 'EU · Ireland' },
  { row: t('pricing.compare.row.support',   locale),
    s: t('pricing.compare.val.email', locale),
    g: t('pricing.compare.val.priority', locale),
    x: t('pricing.compare.val.priorityChat', locale) },
];

const faqKeys = [1, 2, 3, 4, 5, 6, 7];
const faqs = faqKeys.map(i => ({
  q: t(`pricing.faq.q${i}`, locale),
  a: t(`pricing.faq.a${i}`, locale),
}));

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  '@id': canonical,
  name: 'ScanFence',
  description,
  brand: { '@type': 'Brand', name: 'ScanFence' },
  offers: {
    '@type': 'AggregateOffer',
    priceCurrency: 'USD',
    lowPrice: '4.99',
    highPrice: '44.99',
    offerCount: tiers.length,
    availability: 'https://schema.org/InStock',
    url: canonical,
  },
};

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<BaseLayout title={title} description={description} canonical={canonical} jsonLd={jsonLd}>
  <Header />
  <main>
    <section class="pricing-hero">
      <div class="container">
        <span class="eyebrow">{t('pricing.hero.eyebrow', locale)}</span>
        <h1>
          {t('pricing.hero.heading.line1', locale)} <span class="serif-accent">{t('pricing.hero.heading.line2', locale)}</span>
        </h1>
        <p class="pricing-lede">{t('pricing.hero.lede', locale)}</p>
        <div class="metadata-strip">
          <span>{t('common.metadata.usdNet', locale)}</span>
          <span>{t('common.metadata.trial', locale)}</span>
          <span>{t('common.metadata.euIreland', locale)}</span>
          <span>{t('common.metadata.soc2', locale)}</span>
        </div>
      </div>
    </section>

    <section class="pricing-tiers section" data-billing="monthly">
      <div class="container">
        <div class="pricing-billing-toggle" role="tablist" aria-label={t('pricing.billing.label', locale)}>
          <button type="button" data-billing="monthly" class="pricing-billing-btn is-active" role="tab" aria-selected="true">
            {t('pricing.billing.monthly', locale)}
          </button>
          <button type="button" data-billing="annual" class="pricing-billing-btn" role="tab" aria-selected="false">
            {t('pricing.billing.annual', locale)} <span class="pricing-billing-save">{t('pricing.billing.save', locale)}</span>
          </button>
        </div>

        <ul class="pricing-grid">
          {tiers.map(tier => (
            <li class={`pricing-card${tier.featured ? ' pricing-card--featured' : ''}`}>
              <header class="pricing-card-head">
                <span class="eyebrow eyebrow--mute">{tier.eyebrow}</span>
                <h2>{tier.name}</h2>
                <p class="pricing-card-blurb">{tier.blurb}</p>
              </header>
              <div class="pricing-card-price">
                <span class="pricing-card-currency">$</span>
                <span
                  class="pricing-card-amount"
                  data-monthly={tier.priceMonthly}
                  data-annual={tier.priceAnnual}
                >{tier.priceMonthly}</span>
                <span
                  class="pricing-card-cadence"
                  data-monthly={t('pricing.cadenceMonth', locale)}
                  data-annual={t('pricing.cadenceYear', locale)}
                >{t('pricing.cadenceMonth', locale)}</span>
              </div>
              <a href={tier.cta.href} class={`btn ${tier.featured ? 'btn-primary' : 'btn-ghost'} btn-lg pricing-card-cta`}>
                {tier.cta.label}
              </a>
              <ul class="pricing-card-features">
                {tier.features.map(f => (
                  <li><span class="pricing-card-tick" aria-hidden="true">✓</span>{f}</li>
                ))}
              </ul>
            </li>
          ))}
        </ul>

        <div class="pricing-enterprise">
          <div class="pricing-enterprise-copy">
            <span class="eyebrow eyebrow--mute">{t('pricing.enterprise.eyebrow', locale)}</span>
            <h3>{t('pricing.enterprise.heading', locale)}</h3>
            <p>{t('pricing.enterprise.body', locale)}</p>
          </div>
          <a href={`${localizedUrl('/contact/', locale)}?topic=sales`} class="btn btn-ghost btn-lg">{t('pricing.enterprise.cta', locale)}</a>
        </div>
      </div>
    </section>

    <section class="pricing-compare section">
      <div class="container">
        <span class="eyebrow">{t('pricing.compare.eyebrow', locale)}</span>
        <h2>{t('pricing.compare.heading', locale)}</h2>
        <div class="pricing-compare-wrap">
          <table class="pricing-compare-table">
            <thead>
              <tr>
                <th scope="col"></th>
                <th scope="col">{t('pricing.compare.col.basic', locale)}</th>
                <th scope="col">{t('pricing.compare.col.starter', locale)}</th>
                <th scope="col">{t('pricing.compare.col.professional', locale)}</th>
              </tr>
            </thead>
            <tbody>
              {compare.map(row => (
                <tr>
                  <th scope="row">{row.row}</th>
                  <td>{row.s}</td>
                  <td>{row.g}</td>
                  <td>{row.x}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <section class="pricing-faq section">
      <div class="container pricing-faq-container">
        <span class="eyebrow">{t('pricing.faq.eyebrow', locale)}</span>
        <h2>{t('pricing.faq.heading', locale)}</h2>
        <div class="pricing-faq-list">
          {faqs.map((f, i) => (
            <details open={i === 0}>
              <summary>{f.q}</summary>
              <div class="pricing-faq-answer">{f.a}</div>
            </details>
          ))}
        </div>
      </div>
    </section>

    <CTA />
  </main>
  <Footer />
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
</BaseLayout>


<script>
  const root = document.querySelector('.pricing-tiers');
  if (root) {
    const buttons = root.querySelectorAll<HTMLButtonElement>('.pricing-billing-btn');
    const setBilling = (mode: 'monthly' | 'annual') => {
      root.setAttribute('data-billing', mode);
      buttons.forEach(b => {
        const active = b.dataset.billing === mode;
        b.classList.toggle('is-active', active);
        b.setAttribute('aria-selected', String(active));
      });
      root.querySelectorAll<HTMLElement>('.pricing-card-amount').forEach(el => {
        el.textContent = el.dataset[mode] ?? el.textContent;
      });
      root.querySelectorAll<HTMLElement>('.pricing-card-cadence').forEach(el => {
        el.textContent = el.dataset[mode] ?? el.textContent;
      });
    };
    buttons.forEach(b => b.addEventListener('click', () => {
      const mode = b.dataset.billing as 'monthly' | 'annual';
      if (mode) setBilling(mode);
    }));
  }
</script>
