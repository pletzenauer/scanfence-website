---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import Features from '../components/Features.astro';
import Receipt from '../components/Receipt.astro';
import CTA from '../components/CTA.astro';
import { resolveLocale, localizedUrl, t } from '../i18n/t';
import { LOCALE_META } from '../i18n/config';
import { homeGraph } from '../lib/schema';

const locale = resolveLocale(Astro.currentLocale);
const title = t('home.title', locale);
const description = t('site.description', locale);
const canonical = `https://scanfence.com${localizedUrl('/', locale)}`;

const jsonLd = homeGraph({
  homeUrl: canonical,
  description,
  inLanguage: LOCALE_META[locale].hreflang,
});
---

<BaseLayout title={title} description={description} canonical={canonical} jsonLd={jsonLd}>
  <Header />
  <main>
    <Hero />
    <div class="container">
      <div class="metadata-strip">
        <span>{t('common.metadata.qrDynamic', locale)}</span>
        <span>{t('common.metadata.gpsGeofenced', locale)}</span>
        <span>{t('common.metadata.timeAware', locale)}</span>
        <span>{t('common.metadata.euIreland', locale)}</span>
        <span>{t('common.metadata.soc2', locale)}</span>
      </div>
    </div>
    <Features />
    <Receipt />
    <nav class="home-deep-dive" aria-label={t('home.deepDive.eyebrow', locale)}>
      <div class="container">
        <span class="eyebrow eyebrow--mute">{t('home.deepDive.eyebrow', locale)}</span>
        <ul>
          <li><a href={localizedUrl('/features/', locale)}>{t('home.deepDive.features', locale)} →</a></li>
          <li><a href={localizedUrl('/faq/', locale)}>{t('home.deepDive.faq', locale)} →</a></li>
          <li><a href={localizedUrl('/blog/', locale)}>{t('home.deepDive.blog', locale)} →</a></li>
        </ul>
      </div>
    </nav>
    <CTA />
  </main>
  <Footer />
</BaseLayout>
