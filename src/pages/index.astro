---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import Features from '../components/Features.astro';
import Receipt from '../components/Receipt.astro';
import CTA from '../components/CTA.astro';
import { resolveLocale, localizedUrl, t } from '../i18n/t';

const locale = resolveLocale(Astro.currentLocale);
const title = 'ScanFence — Dynamic QR Codes with GPS Geofencing';
const description = t('site.description', locale);
const canonical = `https://scanfence.com${localizedUrl('/', locale)}`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'ScanFence',
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'Web',
  description,
  url: canonical,
  offers: { '@type': 'Offer', priceCurrency: 'EUR', availability: 'https://schema.org/InStock' },
};
---

<BaseLayout title={title} description={description} canonical={canonical} jsonLd={jsonLd}>
  <Header />
  <main>
    <Hero />
    <div class="container">
      <div class="metadata-strip">
        <span>{t('common.metadata.qrDynamic', locale)}</span>
        <span>{t('common.metadata.gpsGeofenced', locale)}</span>
        <span>{t('common.metadata.timeAware', locale)}</span>
        <span>{t('common.metadata.euIreland', locale)}</span>
        <span>{t('common.metadata.soc2', locale)}</span>
      </div>
    </div>
    <Features />
    <Receipt />
    <CTA />
  </main>
  <Footer />
</BaseLayout>
