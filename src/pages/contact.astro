---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const title = 'Contact Scanfence — Talk to our team';
const description = 'Get in touch with Scanfence. We reply within one business day — most questions get answered same-day.';
const canonical = 'https://scanfence.com/contact/';

const topics = [
  { value: 'sales', label: 'Sales' },
  { value: 'technical', label: 'Technical' },
  { value: 'partnership', label: 'Partnership' },
  { value: 'other', label: 'Other' },
];

const chips = [
  { topic: 'sales',       title: 'Sales',        desc: 'Pricing, demos, procurement.' },
  { topic: 'technical',   title: 'Support',      desc: 'Bug reports, integration help.' },
  { topic: 'partnership', title: 'Partnerships', desc: 'Resellers, integrations, OEM.' },
  { topic: 'other',       title: 'Press',        desc: 'Media, interviews, assets.' },
];

const faqs = [
  { q: 'How fast do you reply?',          a: 'Within one business day. Most questions are answered the same day, Monday through Friday (CET).' },
  { q: 'Can I book a product demo?',      a: 'Yes. Pick "Sales" as the topic and mention your preferred time window — we\u2019ll send a calendar invite with a 20-minute walkthrough.' },
  { q: 'Do you offer enterprise SLAs?',   a: 'We offer custom SLAs on our Business and Enterprise plans, including 99.9% uptime commitments and priority support.' },
  { q: 'Where do I find technical docs?', a: 'Head to the Docs section for API references, webhook payloads, and SDK examples.' },
];
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <Header />
  <main>
    <!-- Hero -->
    <section class="contact-hero">
      <div class="container">
        <span class="contact-eyebrow">Contact</span>
        <h1>Let's talk about your QR workflow.</h1>
        <p class="contact-subtitle">
          We reply within one business day. Most questions get answered same-day.
        </p>
        <div class="contact-hero-cta">
          <a href="mailto:hello@scanfence.com" class="btn btn-primary btn-lg">Email us directly</a>
          <a href="#form" class="btn btn-outline btn-lg">Use the form</a>
        </div>
      </div>
    </section>

    <!-- Body: form + info rail -->
    <section class="section contact-body">
      <div class="container">
        <div class="contact-grid">
          <!-- Form card -->
          <div class="contact-form-card" id="form">
            <h2>Send us a message</h2>
            <p class="contact-form-intro">
              Fill out the form and we'll get back to you as soon as possible.
            </p>

            <form class="contact-form elementor-form" method="post" novalidate>
              <input type="hidden" name="post_id"    value="79" />
              <input type="hidden" name="form_id"    value="5f48d34" />
              <input type="hidden" name="queried_id" value="79" />
              <input type="hidden" name="referer_title" value="Contact" />

              <div class="contact-form-row">
                <label for="cf-name">Name<span aria-hidden="true">*</span></label>
                <input
                  id="cf-name"
                  type="text"
                  name="form_fields[name]"
                  required
                  placeholder="Jane Doe"
                  autocomplete="name"
                />
              </div>

              <div class="contact-form-row">
                <label for="cf-email">Work email<span aria-hidden="true">*</span></label>
                <input
                  id="cf-email"
                  type="email"
                  name="form_fields[email]"
                  required
                  placeholder="you@company.com"
                  autocomplete="email"
                />
              </div>

              <div class="contact-form-row">
                <label for="cf-topic">Topic</label>
                <select id="cf-topic" name="form_fields[topic]">
                  {topics.map(t => <option value={t.value}>{t.label}</option>)}
                </select>
              </div>

              <div class="contact-form-row">
                <label for="cf-subject">Subject</label>
                <input
                  id="cf-subject"
                  type="text"
                  name="form_fields[field_a8c66ad]"
                  placeholder="How can we help?"
                />
              </div>

              <div class="contact-form-row">
                <label for="cf-message">Message<span aria-hidden="true">*</span></label>
                <textarea
                  id="cf-message"
                  name="form_fields[message]"
                  rows="5"
                  required
                  placeholder="Tell us a bit about what you're building..."
                ></textarea>
              </div>

              <button type="submit" class="btn btn-primary btn-lg contact-submit">
                <span class="contact-submit-label">Send message</span>
                <span class="contact-submit-spinner" aria-hidden="true"></span>
              </button>

              <p class="contact-form-note">
                By sending this form you agree to be contacted about your inquiry. We never share your data.
              </p>
            </form>

            <div class="contact-form-success" role="status" hidden>
              <h3>Thanks — message received.</h3>
              <p>We'll get back to you within one business day. In the meantime, feel free to email <a href="mailto:hello@scanfence.com">hello@scanfence.com</a>.</p>
            </div>

            <div class="contact-form-error" role="alert" hidden>
              <p>
                Something went wrong sending that. Please email us at
                <a href="mailto:hello@scanfence.com">hello@scanfence.com</a> instead — we'll respond just as fast.
              </p>
            </div>
          </div>

          <!-- Info rail -->
          <aside class="contact-rail">
            <a class="contact-info-card" href="mailto:hello@scanfence.com">
              <div class="contact-info-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              </div>
              <div>
                <div class="contact-info-label">Email</div>
                <div class="contact-info-value">hello@scanfence.com</div>
              </div>
            </a>

            <div class="contact-info-card contact-info-card--static">
              <div class="contact-info-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              </div>
              <div>
                <div class="contact-info-label">Response time</div>
                <div class="contact-info-value">&lt; 24h, Mon–Fri (CET)</div>
              </div>
            </div>

            <div class="contact-info-card contact-info-card--static">
              <div class="contact-info-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s-8-4.5-8-12a8 8 0 1 1 16 0c0 7.5-8 12-8 12z"/><circle cx="12" cy="10" r="3"/></svg>
              </div>
              <div>
                <div class="contact-info-label">Based in</div>
                <div class="contact-info-value">Vienna, Austria — remote-first</div>
              </div>
            </div>

            <div class="contact-info-card contact-info-card--static">
              <div class="contact-info-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
              </div>
              <div>
                <div class="contact-info-label">Docs</div>
                <div class="contact-info-value"><a href="/docs/">Browse documentation →</a></div>
              </div>
            </div>
          </aside>
        </div>
      </div>
    </section>

    <!-- Who should I contact? chips -->
    <section class="section contact-chips-section">
      <div class="container">
        <h2 class="contact-section-title">Who should I contact?</h2>
        <p class="contact-section-subtitle">Pick what fits — we'll route your message to the right person.</p>
        <div class="contact-chips">
          {chips.map(c => (
            <button type="button" class="contact-chip" data-topic={c.topic}>
              <span class="contact-chip-title">{c.title}</span>
              <span class="contact-chip-desc">{c.desc}</span>
              <span class="contact-chip-arrow" aria-hidden="true">→</span>
            </button>
          ))}
        </div>
      </div>
    </section>

    <!-- Mini FAQ -->
    <section class="section contact-faq-section">
      <div class="container contact-faq-container">
        <h2 class="contact-section-title">Frequently asked</h2>
        <div class="contact-faq">
          {faqs.map((f, i) => (
            <details open={i === 0}>
              <summary>{f.q}</summary>
              <div class="contact-faq-answer">{f.a}</div>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- Final CTA -->
    <section class="cta">
      <div class="container">
        <div class="cta-card">
          <h2>Prefer email? Just write us.</h2>
          <p>We read every message. Real humans, fast replies, no ticket queue theatre.</p>
          <div class="cta-buttons">
            <a href="mailto:hello@scanfence.com" class="btn btn-primary btn-lg">hello@scanfence.com</a>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  /* ===== Hero ===== */
  .contact-hero {
    padding: 96px 0 72px;
    text-align: center;
    background: linear-gradient(180deg, var(--color-bg-secondary) 0%, var(--color-bg) 100%);
    position: relative;
    overflow: hidden;
  }
  .contact-hero::before {
    content: '';
    position: absolute;
    top: -180px;
    right: -160px;
    width: 520px;
    height: 520px;
    background: radial-gradient(circle, rgba(99, 102, 241, 0.14) 0%, transparent 70%);
    pointer-events: none;
  }
  .contact-hero::after {
    content: '';
    position: absolute;
    bottom: -160px;
    left: -160px;
    width: 460px;
    height: 460px;
    background: radial-gradient(circle, rgba(129, 140, 248, 0.1) 0%, transparent 70%);
    pointer-events: none;
  }
  .contact-hero .container {
    position: relative;
    z-index: 1;
  }
  .contact-eyebrow {
    display: inline-block;
    font-family: var(--font-heading);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-blue);
    padding: 6px 14px;
    border: 1px solid rgba(99, 102, 241, 0.35);
    border-radius: 999px;
    background: rgba(99, 102, 241, 0.08);
    margin-bottom: 20px;
  }
  .contact-hero h1 {
    font-size: 56px;
    line-height: 1.08;
    max-width: 820px;
    margin: 0 auto 20px;
    letter-spacing: -0.01em;
  }
  .contact-subtitle {
    font-size: 19px;
    color: var(--color-gray-500);
    max-width: 620px;
    margin: 0 auto 36px;
    line-height: 1.6;
  }
  .contact-hero-cta {
    display: flex;
    gap: 14px;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* ===== Body grid ===== */
  .contact-body {
    padding: 72px 0;
  }
  .contact-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(0, 1fr);
    gap: 32px;
    align-items: start;
  }

  /* ===== Form card ===== */
  .contact-form-card {
    background: var(--color-surface);
    border: 1px solid var(--color-gray-200);
    border-radius: var(--radius-xl);
    padding: 40px;
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.25);
  }
  .contact-form-card h2 {
    font-size: 26px;
    margin-bottom: 8px;
  }
  .contact-form-intro {
    color: var(--color-gray-500);
    margin-bottom: 28px;
    font-size: 15px;
  }
  .contact-form-row {
    margin-bottom: 18px;
  }
  .contact-form-row label {
    display: block;
    font-size: 14px;
    font-weight: 600;
    color: var(--color-heading);
    margin-bottom: 8px;
    font-family: var(--font-body);
  }
  .contact-form-row label span {
    color: var(--color-blue);
    margin-left: 4px;
  }
  .contact-form input[type="text"],
  .contact-form input[type="email"],
  .contact-form select,
  .contact-form textarea {
    width: 100%;
    background: var(--color-bg-secondary);
    color: var(--color-white);
    border: 1px solid var(--color-gray-200);
    border-radius: var(--radius);
    padding: 12px 14px;
    font-family: var(--font-body);
    font-size: 15px;
    line-height: 1.5;
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  .contact-form input:focus,
  .contact-form select:focus,
  .contact-form textarea:focus {
    outline: none;
    border-color: var(--color-blue);
    box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.2);
  }
  .contact-form textarea {
    resize: vertical;
    min-height: 120px;
  }
  .contact-form select {
    appearance: none;
    -webkit-appearance: none;
    background-image: url("data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' width='12' height='8' viewBox='0 0 12 8'%3e%3cpath fill='%2394a3b8' d='M6 8 0 0h12z'/%3e%3c/svg%3e");
    background-repeat: no-repeat;
    background-position: right 14px center;
    padding-right: 40px;
  }
  .contact-submit {
    width: 100%;
    margin-top: 8px;
    position: relative;
  }
  .contact-submit[data-loading="true"] .contact-submit-label { visibility: hidden; }
  .contact-submit-spinner {
    display: none;
    position: absolute;
    inset: 0;
    margin: auto;
    width: 18px;
    height: 18px;
    border: 2px solid rgba(255,255,255,0.35);
    border-top-color: #fff;
    border-radius: 50%;
    animation: contact-spin 0.8s linear infinite;
  }
  .contact-submit[data-loading="true"] .contact-submit-spinner { display: block; }
  @keyframes contact-spin { to { transform: rotate(360deg); } }
  .contact-form-note {
    font-size: 13px;
    color: var(--color-gray-500);
    text-align: center;
    margin-top: 14px;
    line-height: 1.5;
  }
  .contact-form-success,
  .contact-form-error {
    padding: 24px;
    border-radius: var(--radius-lg);
    margin-top: 8px;
  }
  .contact-form-success {
    background: rgba(99, 102, 241, 0.08);
    border: 1px solid rgba(99, 102, 241, 0.35);
  }
  .contact-form-success h3 {
    font-size: 20px;
    margin-bottom: 8px;
    color: var(--color-heading);
  }
  .contact-form-success p,
  .contact-form-error p {
    font-size: 15px;
    color: var(--color-text);
    line-height: 1.6;
  }
  .contact-form-success a,
  .contact-form-error a {
    color: var(--color-blue);
    font-weight: 600;
  }
  .contact-form-error {
    background: rgba(239, 68, 68, 0.08);
    border: 1px solid rgba(239, 68, 68, 0.35);
    margin-bottom: 12px;
  }

  /* ===== Info rail ===== */
  .contact-rail {
    display: flex;
    flex-direction: column;
    gap: 12px;
    position: sticky;
    top: calc(var(--header-height) + 24px);
  }
  .contact-info-card {
    display: flex;
    align-items: center;
    gap: 16px;
    background: var(--color-surface);
    border: 1px solid var(--color-gray-200);
    border-radius: var(--radius-lg);
    padding: 20px 22px;
    color: var(--color-text);
    text-decoration: none;
    transition: border-color 0.15s, transform 0.15s, box-shadow 0.15s;
  }
  .contact-info-card:hover:not(.contact-info-card--static) {
    border-color: rgba(99, 102, 241, 0.5);
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(99, 102, 241, 0.15);
  }
  .contact-info-icon {
    width: 40px;
    height: 40px;
    display: grid;
    place-items: center;
    border-radius: var(--radius);
    background: rgba(99, 102, 241, 0.12);
    color: var(--color-blue);
    flex-shrink: 0;
  }
  .contact-info-icon svg {
    width: 20px;
    height: 20px;
  }
  .contact-info-label {
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-gray-500);
    margin-bottom: 2px;
    font-weight: 600;
  }
  .contact-info-value {
    font-size: 15px;
    color: var(--color-heading);
    font-weight: 500;
  }
  .contact-info-value a {
    color: var(--color-blue);
  }

  /* ===== Chips ===== */
  .contact-chips-section {
    padding: 24px 0 64px;
  }
  .contact-section-title {
    font-size: 32px;
    text-align: center;
    margin-bottom: 8px;
  }
  .contact-section-subtitle {
    text-align: center;
    color: var(--color-gray-500);
    font-size: 16px;
    max-width: 540px;
    margin: 0 auto 36px;
  }
  .contact-chips {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 14px;
  }
  .contact-chip {
    text-align: left;
    background: var(--color-surface);
    border: 1px solid var(--color-gray-200);
    border-radius: var(--radius-lg);
    padding: 22px 22px 20px;
    color: var(--color-text);
    cursor: pointer;
    font-family: var(--font-body);
    transition: border-color 0.15s, transform 0.15s, box-shadow 0.15s;
    display: flex;
    flex-direction: column;
    gap: 6px;
    position: relative;
  }
  .contact-chip:hover {
    border-color: rgba(99, 102, 241, 0.5);
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(99, 102, 241, 0.15);
  }
  .contact-chip-title {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 17px;
    color: var(--color-heading);
  }
  .contact-chip-desc {
    font-size: 14px;
    color: var(--color-gray-500);
    line-height: 1.45;
  }
  .contact-chip-arrow {
    position: absolute;
    top: 18px;
    right: 20px;
    color: var(--color-blue);
    font-size: 16px;
    transition: transform 0.15s;
  }
  .contact-chip:hover .contact-chip-arrow {
    transform: translateX(4px);
  }

  /* ===== FAQ ===== */
  .contact-faq-section {
    padding: 24px 0 72px;
  }
  .contact-faq-container {
    max-width: 760px;
  }
  .contact-faq details {
    border: 1px solid var(--color-gray-200);
    border-radius: var(--radius-lg);
    margin-bottom: 12px;
    overflow: hidden;
    background: var(--color-surface);
  }
  .contact-faq summary {
    padding: 18px 22px;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 16px;
    color: var(--color-heading);
    cursor: pointer;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
  }
  .contact-faq summary::-webkit-details-marker { display: none; }
  .contact-faq summary::after {
    content: '+';
    color: var(--color-blue);
    font-size: 22px;
    font-weight: 400;
    line-height: 1;
    transition: transform 0.2s;
  }
  .contact-faq details[open] summary::after {
    content: '−';
  }
  .contact-faq-answer {
    padding: 0 22px 18px;
    color: var(--color-text);
    font-size: 15px;
    line-height: 1.65;
  }

  /* ===== Responsive ===== */
  @media (max-width: 900px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
    .contact-rail {
      position: static;
    }
    .contact-hero {
      padding: 72px 0 56px;
    }
    .contact-hero h1 {
      font-size: 40px;
    }
    .contact-subtitle {
      font-size: 17px;
    }
    .contact-form-card {
      padding: 28px 22px;
    }
    .contact-chips {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
    .contact-section-title {
      font-size: 26px;
    }
  }

  @media (max-width: 520px) {
    .contact-hero h1 {
      font-size: 32px;
    }
    .contact-chips {
      grid-template-columns: 1fr;
    }
    .contact-hero-cta .btn {
      width: 100%;
    }
  }
</style>

<script is:inline>
  (() => {
    const form = document.querySelector('.contact-form');
    if (!form) return;

    const submitBtn = form.querySelector('.contact-submit');
    const topicSelect = form.querySelector('#cf-topic');
    const successPanel = document.querySelector('.contact-form-success');
    const errorPanel = document.querySelector('.contact-form-error');

    // Prefill topic from ?topic= or from chip clicks
    const params = new URLSearchParams(window.location.search);
    const topicParam = params.get('topic');
    if (topicParam && topicSelect) {
      const match = [...topicSelect.options].find(o => o.value === topicParam);
      if (match) topicSelect.value = topicParam;
    }

    // Chip clicks: set topic + scroll to form
    document.querySelectorAll('.contact-chip').forEach(chip => {
      chip.addEventListener('click', () => {
        const topic = chip.getAttribute('data-topic');
        if (topic && topicSelect) {
          const match = [...topicSelect.options].find(o => o.value === topic);
          if (match) topicSelect.value = topic;
        }
        const target = document.getElementById('form');
        if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        const firstInput = form.querySelector('#cf-name');
        if (firstInput) setTimeout(() => firstInput.focus(), 500);
      });
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      errorPanel.hidden = true;
      submitBtn.setAttribute('data-loading', 'true');
      submitBtn.disabled = true;

      try {
        const fd = new FormData(form);
        fd.append('action', 'elementor_pro_forms_send_form');
        fd.append('referer', window.location.href);

        const res = await fetch('https://scanfence.com/wp-admin/admin-ajax.php', {
          method: 'POST',
          body: fd,
          credentials: 'omit',
        });

        if (!res.ok) throw new Error('HTTP ' + res.status);
        const data = await res.json().catch(() => ({ success: true }));
        if (data && data.success === false) throw new Error('form rejected');

        form.hidden = true;
        successPanel.hidden = false;
        successPanel.scrollIntoView({ behavior: 'smooth', block: 'center' });
      } catch (err) {
        console.error('[contact] submit failed', err);
        errorPanel.hidden = false;
        submitBtn.removeAttribute('data-loading');
        submitBtn.disabled = false;
      }
    });
  })();
</script>
