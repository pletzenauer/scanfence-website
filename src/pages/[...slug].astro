---
import { getPages, getAllPosts, rewriteWPLinks, rewriteSchemaUrls, rewriteCanonicalUrl, descriptionExcerpt, demoteExtraH1s } from '../lib/wordpress';
import PageLayout from '../layouts/PageLayout.astro';
import { DEFAULT_LOCALE } from '../i18n/config';
import { pageAvailableLocales } from '../i18n/wp-cache';

export async function getStaticPaths() {
  const [pages, posts] = await Promise.all([getPages(), getAllPosts()]);
  const postSlugs = new Set(posts.map(p => p.slug));
  const excludedSlugs = ['homepage', 'blog', 'sample-page', 'contact', 'pricing'];
  return pages
    .filter(p => !excludedSlugs.includes(p.slug))
    .map(p => ({ params: { slug: p.slug }, props: { page: p, postSlugs: [...postSlugs] } }));
}

const locale = DEFAULT_LOCALE;
const { page, postSlugs } = Astro.props;
const seo = page.yoast_head_json;
const knownPostSlugs = new Set<string>(postSlugs);
const rewrittenContent = demoteExtraH1s(rewriteWPLinks(page.content.rendered, knownPostSlugs));
const fixedSchema = seo?.schema
  ? rewriteSchemaUrls(seo.schema, knownPostSlugs)
  : undefined;
const canonical = rewriteCanonicalUrl(seo?.canonical, knownPostSlugs);
const description = seo?.description || descriptionExcerpt(page.content.rendered);
const availableLocales = pageAvailableLocales(page.slug);
---

<PageLayout
  title={seo?.title || page.title.rendered}
  pageTitle={page.title.rendered}
  description={description}
  canonical={canonical}
  ogImage={seo?.og_image?.[0]?.url}
  jsonLd={fixedSchema}
  locale={locale}
  availableLocales={availableLocales}
>
  <Fragment set:html={rewrittenContent} />
</PageLayout>
