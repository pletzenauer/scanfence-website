---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { resolveLocale, localizedUrl, t } from '../i18n/t';

const locale = resolveLocale(Astro.currentLocale);
const title = t('error.title', locale);
const description = t('error.description', locale);
---

<BaseLayout title={title} description={description} robots="noindex,follow">
  <Header />
  <main>
    <section class="error-hero">
      <div class="container">
        <span class="eyebrow">{t('error.eyebrow', locale)}</span>
        <h1>
          {t('error.heading.line1', locale)} <span class="serif-accent">{t('error.heading.line2', locale)}</span>
        </h1>
        <p class="error-lede">{t('error.lede', locale)}</p>
        <ul class="error-links">
          <li><a href={localizedUrl('/', locale)}>{t('error.link.home', locale)}</a></li>
          <li><a href={localizedUrl('/features/', locale)}>{t('error.link.features', locale)}</a></li>
          <li><a href={localizedUrl('/pricing/', locale)}>{t('error.link.pricing', locale)}</a></li>
          <li><a href={localizedUrl('/blog/', locale)}>{t('error.link.blog', locale)}</a></li>
          <li><a href={localizedUrl('/documentation/', locale)}>{t('error.link.docs', locale)}</a></li>
          <li><a href={localizedUrl('/contact/', locale)}>{t('error.link.contact', locale)}</a></li>
        </ul>
        <div class="error-cta">
          <a href={localizedUrl('/', locale)} class="btn btn-primary btn-lg">{t('error.cta.home', locale)}</a>
          <a href="mailto:hello@scanfence.com" class="btn btn-ghost btn-lg">{t('error.cta.email', locale)}</a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .error-hero {
    padding: var(--space-9) 0;
    background: var(--d01-paper);
    border-bottom: var(--rule-hard);
  }
  .error-hero h1 {
    font-size: clamp(48px, 6vw, 80px);
    font-weight: 500;
    line-height: 1.02;
    letter-spacing: -0.02em;
    margin: var(--space-3) 0 var(--space-5);
  }
  .error-lede {
    font-size: 18px;
    color: var(--d01-steel);
    line-height: 1.55;
    margin-bottom: var(--space-6);
    max-width: 56ch;
  }
  .error-links {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-7);
    border-top: var(--rule-hard);
  }
  .error-links li {
    border-bottom: var(--rule);
    padding: var(--space-3) 0;
  }
  .error-links a {
    font-family: var(--font-display);
    font-size: 18px;
    color: var(--d01-ink);
    text-decoration: none;
  }
  .error-links a:hover { color: var(--d01-signal); }
  .error-cta { display: flex; gap: var(--space-4); flex-wrap: wrap; }
</style>
