---
import { resolveLocale, t } from '../i18n/t';

const locale = resolveLocale(Astro.currentLocale);

const items = ['01', '02', '03', '04', '05', '06'].map(n => ({
  n,
  title: t(`features.${n}.title`, locale),
  body: t(`features.${n}.body`, locale),
}));
---

<section class="features section" id="features">
  <div class="container">
    <header class="features-header">
      <span class="eyebrow">{t('features.eyebrow', locale)}</span>
      <h2>
        {t('features.heading.line1', locale)}<br />
        <span class="serif-accent">{t('features.heading.line2', locale)}</span>
      </h2>
    </header>

    <ul class="features-list">
      {items.map(item => (
        <li class="features-item">
          <span class="features-num">{item.n}</span>
          <div class="features-body">
            <h3>{item.title}</h3>
            <p>{item.body}</p>
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>
