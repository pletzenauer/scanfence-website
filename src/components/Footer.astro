---
import { resolveLocale, localizedUrl, t } from '../i18n/t';

const locale = resolveLocale(Astro.currentLocale);
const year = new Date().getFullYear();
---
<footer class="footer">
  <div class="container">
    <div class="footer-top">
      <a href={localizedUrl('/', locale)} class="footer-logo" aria-label={t('footer.logoAria', locale)}>
        <span class="footer-logo-mark" aria-hidden="true"></span>
        <span class="footer-logo-text">ScanFence</span>
      </a>
      <p class="footer-tagline">
        {t('footer.tagline.lead', locale)} <span class="serif-accent">{t('footer.tagline.accent', locale)}</span>
      </p>
      <a href="mailto:hello@scanfence.com" class="footer-email">hello@scanfence.com →</a>
    </div>
    <div class="footer-meta metadata-strip">
      <span>{t('footer.copyright', locale, { year })}</span>
      <span>{t('footer.region', locale)}</span>
      <span>{t('footer.version', locale)}</span>
      <span>{t('footer.soc2', locale)}</span>
      <span>
        <a href={localizedUrl('/datenschutzerklaerung/', locale)}>{t('footer.privacy', locale)}</a>
        ·
        <a href={localizedUrl('/terms-and-conditions/', locale)}>{t('footer.terms', locale)}</a>
      </span>
    </div>
  </div>
</footer>
