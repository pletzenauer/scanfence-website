    <div class="footer-meta metadata-strip">
      <span>© {year} ScanFence</span>
      <span>EU · IRELAND-1</span>
      <span>v2.4.1</span>
      <span>SOC-2 TYPE II</span>
      <span><a href="/datenschutzerklaerung/">Privacy</a> · <a href="/terms-and-conditions/">Terms</a></span>
