---
import { resolveLocale, localizedUrl, stripLocalePrefix, t } from '../i18n/t';
import LanguageSwitcher from './LanguageSwitcher.astro';

const locale = resolveLocale(Astro.currentLocale);
const { path: canonicalPath } = stripLocalePrefix(Astro.url.pathname);
const isActive = (href: string) => {
  if (href === '/') return canonicalPath === '/';
  return canonicalPath.startsWith(href);
};
const nav = [
  { href: '/',               key: 'nav.home' },
  { href: '/features/',      key: 'nav.features' },
  { href: '/pricing/',       key: 'nav.pricing' },
  { href: '/faq/',           key: 'nav.faq' },
  { href: '/documentation/', key: 'nav.docs' },
  { href: '/blog/',          key: 'nav.blog' },
  { href: '/contact/',       key: 'nav.contact' },
];
---

<header class="header">
  <div class="container">
    <a href={localizedUrl('/', locale)} class="header-logo" aria-label="ScanFence — home">
      <span class="header-logo-mark" aria-hidden="true"></span>
      <span class="header-logo-text">ScanFence</span>
    </a>

    <nav class="header-nav" aria-label={t('nav.primary', locale)}>
      {nav.map(item => (
        <a
          href={localizedUrl(item.href, locale)}
          class:list={[{ 'is-active': isActive(item.href) }]}
        >{t(item.key, locale)}</a>
      ))}
    </nav>

    <div class="header-actions">
      <LanguageSwitcher />
      <a href="https://app.scanfence.com/login" class="header-link">{t('nav.signIn', locale)}</a>
      <a href="https://app.scanfence.com/signup" class="btn btn-primary btn-nav">{t('nav.startPlan', locale)}</a>
    </div>

    <button class="mobile-toggle" aria-label={t('nav.toggleMenu', locale)} aria-controls="mobileMenu" aria-expanded="false" id="menuToggle">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
      </svg>
    </button>
  </div>
</header>

<div class="mobile-menu" id="mobileMenu">
  {nav.map(item => (
    <a
      href={localizedUrl(item.href, locale)}
      class:list={[{ 'is-active': isActive(item.href) }]}
      aria-current={isActive(item.href) ? 'page' : undefined}
    >{t(item.key, locale)}</a>
  ))}
  <hr class="rule-hard" />
  <LanguageSwitcher />
  <a href="https://app.scanfence.com/login">{t('nav.signIn', locale)}</a>
  <a href="https://app.scanfence.com/signup" class="btn btn-primary">{t('nav.startPlan', locale)}</a>
</div>

<script>
  const menuToggle = document.getElementById('menuToggle');
  const mobileMenu = document.getElementById('mobileMenu');
  if (menuToggle && mobileMenu) {
    let isOpen = false;
    menuToggle.addEventListener('click', () => {
      isOpen = !isOpen;
      mobileMenu.classList.toggle('active', isOpen);
      menuToggle.setAttribute('aria-expanded', String(isOpen));
      const path = menuToggle.querySelector('svg path');
      if (path) {
        path.setAttribute('d', isOpen
          ? 'M6 18L18 6M6 6l12 12'
          : 'M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5'
        );
      }
    });
    mobileMenu.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        isOpen = false;
        mobileMenu.classList.remove('active');
        menuToggle.setAttribute('aria-expanded', 'false');
        const path = menuToggle.querySelector('svg path');
        if (path) path.setAttribute('d', 'M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5');
      });
    });
  }
</script>
